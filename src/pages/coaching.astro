    border-radius: 4px;
  }

  /* --- PROBLEM --- */
  .problem { padding: 7rem 2rem; background: var(--color-cream); text-align: center; }
  .problem-inner { max-width: 780px; margin: 0 auto; }
  .problem h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 3.5vw, 2.8rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--color-charcoal);
    margin-bottom: 2rem;
  }
  .problem h2 em { font-style: italic; color: var(--color-gold); font-weight: 400; }
  .problem p {
    font-size: 1.08rem;
    color: var(--color-charcoal);
    line-height: 1.85;
    margin-bottom: 1.25rem;
  }
  .problem p:last-child { margin-bottom: 0; }

  /* --- WHO FOR --- */
  .whofor { padding: 7rem 2rem; background: var(--color-bg-white); }
  .whofor-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: start;
  }
  .whofor h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 3.2vw, 2.6rem);
    font-weight: 400;
