    color: var(--color-navy);
  }

  /* --- FOR / NOT FOR (merged) --- */
  .forwho { padding: 7rem 2rem; background: var(--color-bg-white); }
  .forwho-inner { max-width: 1100px; margin: 0 auto; }
  .forwho h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 3.5vw, 2.6rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }
  .forwho h2 em { font-style: italic; color: var(--color-gold); font-weight: 400; }
  .forwho-intro {
    color: var(--color-slate);
    font-size: 1.04rem;
    line-height: 1.8;
    max-width: 680px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }
  .forwho-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .forwho-col {
    padding: 2.5rem;
    border-radius: 8px;
  }
  .forwho-for {
    background: var(--color-cream);
    border-left: 3px solid var(--color-gold);
  }
  .forwho-notfor {
    background: var(--color-bg-cool);
    border-left: 3px solid var(--color-slate);
  }
  .forwho-col h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-charcoal);
    margin-bottom: 0.85rem;
    line-height: 1.3;
  }
  .forwho-col h3 em { font-style: italic; color: var(--color-gold); font-weight: 400; }
  .forwho-sub {
    color: var(--color-slate);
    font-size: 0.98rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }
  .checklist { list-style: none; padding: 0; }
  .checklist li {
    padding: 1rem 0 1rem 2rem;
    border-bottom: 1px solid var(--color-border-warm);
    font-size: 1rem;
    color: var(--color-charcoal);
    position: relative;
    line-height: 1.6;
  }
  .checklist li em { font-style: italic; color: var(--color-gold); }
  .checklist li:last-child { border-bottom: none; }
  .checklist li::before {
    content: '—';
    position: absolute; left: 0; top: 1rem;
    color: var(--color-gold); font-weight: 500;
  }
  .notlist { list-style: none; padding: 0; }
  .notlist li {
    padding: 1rem 0 1rem 1.6rem;
    border-bottom: 1px solid rgba(107, 123, 141, 0.25);
    font-size: 0.98rem;
    color: var(--color-slate);
    position: relative;
    line-height: 1.7;
  }
  .notlist li:last-child { border-bottom: none; }
  .notlist li::before {
    content: '×';
    position: absolute; left: 0; top: 0.95rem;
    color: var(--color-slate);
    font-weight: 500;
  }

  /* --- PROGRAMME --- */
  .programme { padding: 8rem 2rem; background: var(--color-navy); color: var(--color-cream); }
  .programme-inner { max-width: 1100px; margin: 0 auto; }
  .programme .section-tag { color: var(--color-gold); }
  .programme h2 {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    font-weight: 400; line-height: 1.15;
    color: var(--color-cream); margin-bottom: 2rem;
  }
  .programme h2 em { font-style: italic; color: var(--color-gold); }
  .programme-intro {
    font-size: 1.08rem;
    color: rgba(245, 240, 232, 0.78);
    max-width: 720px;
    line-height: 1.85;
    margin-bottom: 4rem;
  }
  .section-head { text-align: center; margin-bottom: 2rem; }
  .section-head .programme-intro { margin-left: auto; margin-right: auto; }

  /* --- TIMELINE DIAGRAM --- */
  .timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto 5rem;
    padding: 2rem 0 0;
  }
  .timeline-track {
    position: absolute;
    top: 2.8rem;
    left: 8%;
    right: 8%;
    height: 2px;
    background: rgba(196, 162, 101, 0.25);
  }
  .timeline-fill {
    position: absolute;
    top: 2.8rem;
    left: 8%;
    width: 0;
    height: 2px;
    background: var(--color-gold);
    transition: width 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .timeline.visible .timeline-fill { width: 84%; }

  .timeline-points {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    position: relative;
    z-index: 2;
  }
  .tl-point {
    text-align: center;
  }
  .tl-circle {
    width: 3.2rem;
    height: 3.2rem;
    margin: 0 auto;
    background: var(--color-navy);
    border: 2px solid var(--color-gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-gold);
    position: relative;
    transition: all 0.3s;
  }
  .tl-circle::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(196, 162, 101, 0.25);
  }
  .tl-label {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .tl-weeks {
    font-family: var(--font-heading-sc);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: rgba(245, 240, 232, 0.55);
    text-transform: uppercase;
  }
  .tl-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-gold-subtle);
  }

  .phases { display: grid; gap: 2.5rem; }
  .phase {
    padding: 2.5rem;
    background: rgba(245, 240, 232, 0.03);
    border: 1px solid rgba(196, 162, 101, 0.18);
    border-left: 3px solid var(--color-gold);
    border-radius: 6px;
  }
  .phase-marker {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  .phase-num {
    font-family: var(--font-heading-sc);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--color-gold);
  }
  .phase-weeks {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(245, 240, 232, 0.5);
  }
  .phase h3 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 400;
    color: var(--color-cream);
    margin-bottom: 0.8rem;
  }
  .phase-lead {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-gold-subtle);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .phase ul { list-style: none; padding: 0; }
  .phase li {
    padding: 0.7rem 0 0.7rem 1.6rem;
    font-size: 0.98rem;
    color: rgba(245, 240, 232, 0.82);
    line-height: 1.7;
    position: relative;
  }
  .phase li em { font-style: italic; color: var(--color-gold); }
  .phase li::before {
    content: '·';
    position: absolute; left: 0.3rem; top: 0.7rem;
    color: var(--color-gold);
    font-size: 1.5rem; line-height: 1;
  }
  .phase li + li { border-top: 1px solid rgba(245, 240, 232, 0.06); }

  /* --- WHAT YOU GET --- */
  .whatyouget { padding: 7rem 2rem; background: var(--color-bg-white); }
  .whatyouget-inner { max-width: 1100px; margin: 0 auto; }
  .whatyouget h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.8vw, 2.8rem);
    font-weight: 400; line-height: 1.2;
    color: var(--color-charcoal); margin-bottom: 1.5rem;
  }
  .whatyouget h2 em { font-style: italic; color: var(--color-gold); }
  .wyg-intro {
    color: var(--color-slate);
    font-size: 1.05rem; line-height: 1.8;
    max-width: 680px; margin: 0 auto 4rem;
  }
  .inclusions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .inclusion {
    padding: 2rem;
    background: var(--color-cream);
    border-left: 2px solid var(--color-gold);
    border-radius: 4px;
  }
  .inclusion-num {
    font-family: var(--font-heading-sc);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    display: block; margin-bottom: 0.8rem;
  }
  .inclusion h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--color-charcoal);
    line-height: 1.3; margin-bottom: 0.7rem;
  }
  .inclusion p {
    font-size: 0.98rem; color: var(--color-slate);
    line-height: 1.75;
  }

  /* --- PORTAL PREVIEW (screenshots) --- */
  .portal-preview { padding: 7rem 2rem; background: var(--color-bg-cool); }
  .portal-preview-inner { max-width: 1200px; margin: 0 auto; }
  .portal-preview h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.8vw, 2.8rem);
    font-weight: 400; line-height: 1.2;
    color: var(--color-charcoal);
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .portal-preview h2 em { font-style: italic; color: var(--color-gold); }
  .portal-preview-intro {
    color: var(--color-slate);
    font-size: 1.04rem; line-height: 1.8;
    max-width: 660px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }
  .portal-shots {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }
  .shot {
    margin: 0;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-warm);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(28, 42, 58, 0.08);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .shot:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px rgba(28, 42, 58, 0.12);
  }
  .shot img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top left;
    display: block;
    border-bottom: 1px solid var(--color-border-warm);
  }
  .shot figcaption {
    padding: 1rem 1.25rem;
    font-family: var(--font-heading-sc);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: var(--color-slate);
    text-transform: uppercase;
    text-align: center;
  }

  /* --- PILLARS STRIP (shortened) --- */
  .pillars-strip {
    padding: 3.5rem 2rem;
    background: var(--color-navy);
    color: var(--color-cream);
    text-align: center;
    position: relative;
  }
  .pillars-strip::before {
    content: ''; position: absolute; top: 0; left: 50%;
    transform: translateX(-50%);
    width: 80px; height: 2px; background: var(--color-gold);
  }
  .pillars-strip-inner { max-width: 1000px; margin: 0 auto; }
  .pillars-strip .section-tag { color: var(--color-gold); margin-bottom: 1.25rem; }
  .pillars-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 1.25rem;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    color: var(--color-cream);
    line-height: 1.5;
  }
  .pillars-line em {
    font-style: italic;
    color: var(--color-gold);
  }
  .pillars-dot {
    color: var(--color-gold);
    opacity: 0.6;
    font-size: 1.4rem;
  }

  /* --- AUTHORITY STACK --- */
  .authority {
    padding: 7rem 2rem;
    background: var(--color-cream);
  }
  .authority-inner { max-width: 1100px; margin: 0 auto; }
  .authority h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.8vw, 2.8rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }
  .authority h2 em { font-style: italic; color: var(--color-gold); font-weight: 400; }
  .authority-intro {
    color: var(--color-slate);
    font-size: 1.04rem;
    line-height: 1.8;
    max-width: 720px;
    margin: 0 auto 3.5rem;
  }
  .authority-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .auth-card {
    padding: 1.75rem 1.5rem;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-warm);
    border-top: 2px solid var(--color-gold);
    border-radius: 6px;
  }
  .auth-num {
    font-family: var(--font-heading-sc);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    display: block;
    margin-bottom: 0.7rem;
  }
  .auth-card h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-charcoal);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }
  .auth-card p {
    font-size: 0.93rem;
    color: var(--color-slate);
    line-height: 1.65;
  }
  .authority-note {
    margin-top: 2.75rem;
    text-align: center;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.98rem;
    color: var(--color-slate);
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--color-border-warm);
    border-bottom: 1px solid var(--color-border-warm);
  }

  /* --- PROOF / TESTIMONIALS --- */
  .proof {
    padding: 7rem 2rem;
    background: var(--color-bg-white);
  }
  .proof-inner { max-width: 1100px; margin: 0 auto; }
  .proof h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 3.5vw, 2.6rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-charcoal);
    margin-bottom: 1.25rem;
  }
  .proof h2 em { font-style: italic; color: var(--color-gold); font-weight: 400; }
  .proof-cohort-line {
    font-family: var(--font-heading-sc);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--color-slate);
    margin-bottom: 1.75rem;
    text-transform: uppercase;
  }
  .proof-applicants {
    color: var(--color-gold);
    font-style: italic;
    letter-spacing: 0.1em;
    text-transform: none;
  }
  .proof-intro {
    color: var(--color-slate);
    font-size: 0.98rem;
    line-height: 1.8;
    max-width: 680px;
    margin: 0 auto 3.5rem;
    font-style: italic;
  }
  .testimonials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }
  .testimonial {
    margin: 0;
    padding: 2rem 1.75rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border-warm);
    border-left: 3px solid var(--color-gold);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
  }
  .testimonial-tag {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    opacity: 0.7;
    margin-bottom: 1rem;
    display: block;
    font-style: italic;
  }
  .testimonial blockquote {
    margin: 0 0 1.25rem;
    padding: 0;
    border: none;
    flex: 1;
  }
  .testimonial blockquote p {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.75;
    color: var(--color-charcoal);
  }
  .testimonial blockquote p em {
    font-style: italic;
    color: var(--color-gold);
  }
  .testimonial figcaption {
    font-family: var(--font-heading-sc);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--color-slate);
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-warm);
    text-transform: uppercase;
  }

  /* --- PRICING --- */
  .pricing { padding: 8rem 2rem; background: var(--color-cream); }
  .pricing-inner { max-width: 1100px; margin: 0 auto; }
  .pricing h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 400; line-height: 1.2;
    color: var(--color-charcoal); margin-bottom: 1.5rem;
  }
  .pricing h2 em { font-style: italic; color: var(--color-gold); }
  .pricing-intro {
    color: var(--color-slate);
    font-size: 1.05rem; line-height: 1.85;
    max-width: 700px; margin: 0 auto 4rem;
  }
  .plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: stretch;
  }
  .plan {
    padding: 2.25rem 2rem;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-warm);
    border-radius: 8px;
    display: flex; flex-direction: column;
    text-align: center;
  }
  .plan-featured {
    border-color: var(--color-gold);
    border-width: 2px;
    box-shadow: 0 6px 20px rgba(196, 162, 101, 0.12);
    transform: translateY(-10px);
  }
  .plan-tag {
    font-family: var(--font-heading-sc);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--color-slate);
    margin-bottom: 1.25rem;
  }
  .plan-featured .plan-tag { color: var(--color-gold); }
  .plan-price {
    font-family: var(--font-heading);
    font-size: 3.2rem;
    font-weight: 400;
    color: var(--color-navy);
    line-height: 1;
  }
  .plan-price .currency {
    font-size: 1.8rem;
    vertical-align: top;
    margin-right: 0.2rem;
  }
  .plan-period {
    font-size: 1.1rem;
    color: var(--color-slate);
    margin-left: 0.5rem;
  }
  .plan-perhour {
    font-family: var(--font-heading-sc);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    margin-top: 0.8rem;
  }
  .plan-note {
    font-size: 0.88rem;
    color: var(--color-slate);
    margin-top: 0.4rem;
    margin-bottom: 1.5rem;
  }

  /* Price anchor (was £1000 → now £600) */
  .price-anchor {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    margin: 0 auto 1.75rem;
    padding: 0.9rem 1.75rem;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-warm);
    border-radius: 999px;
    box-shadow: 0 4px 12px rgba(28, 42, 58, 0.06);
  }
  .anchor-item {
    display: flex;
    flex-direction: column;
    text-align: center;
    line-height: 1.2;
  }
  .anchor-item s {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-slate);
    text-decoration-color: rgba(220, 80, 80, 0.55);
    text-decoration-thickness: 1.5px;
  }
  .anchor-item strong {
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 1.6rem;
    color: var(--color-navy);
  }
  .anchor-item span:last-child {
    font-family: var(--font-heading-sc);
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    color: var(--color-slate);
    margin-top: 0.2rem;
    text-transform: uppercase;
  }
  .anchor-is span:last-child {
    color: var(--color-gold);
  }
  .anchor-arrow {
    font-size: 1.3rem;
    color: var(--color-gold);
  }

  /* Value stack */
  .value-stack {
    max-width: 780px;
    margin: 4rem auto 0;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-warm);
    border-top: 3px solid var(--color-gold);
    border-radius: 8px;
    padding: 2.25rem 2.5rem;
  }
  .value-stack h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--color-charcoal);
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .value-stack h3 em { font-style: italic; color: var(--color-gold); }
  .value-grid { display: flex; flex-direction: column; }
  .value-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(212, 201, 184, 0.5);
    font-size: 0.95rem;
  }
  .value-row:last-child { border-bottom: none; }
  .value-what {
    color: var(--color-charcoal);
    line-height: 1.5;
    flex: 1;
  }
  .value-worth {
    font-family: var(--font-heading-sc);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    white-space: nowrap;
  }
  .value-total {
    padding-top: 1.1rem;
    margin-top: 0.4rem;
    border-top: 1px solid var(--color-border-warm) !important;
  }
  .value-total .value-what,
  .value-total .value-worth {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-navy);
    letter-spacing: 0;
  }
  .value-price {
    padding: 1rem 1.25rem;
    margin-top: 0.6rem;
    background: var(--color-gold);
    border-radius: 4px;
    border-bottom: none !important;
  }
  .value-price .value-what,
  .value-price .value-worth {
